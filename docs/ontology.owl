        <terms:contributor>École de Technologie Supérieure (ÉTS)</terms:contributor>
        <terms:creator>Adam Yousfi</terms:creator>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-06-23</terms:date>
        <terms:license rdf:resource="https://creativecommons.org/publicdomain/zero/1.0/"/>
        <terms:title xml:lang="en">WLCONTO: Whole-Life Costing Ontology</terms:title>
        <vann:preferredNamespacePrefix>wlconto</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#</vann:preferredNamespaceUri>
        <rdfs:comment xml:lang="en">Public release of WLCONTO (schema only, without example individuals). Ontology describing the ISO 15686-5 Whole-Life Costing standard.
Adam Yousfi, École de Technologie Supérieure (ÉTS), Montréal.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://adamY76.github.io/WLC-PLATFORM-ETS/"/>
        <rdfs:seeAlso rdf:resource="https://w3id.org/wlconto"/>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


