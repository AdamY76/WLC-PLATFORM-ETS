@prefix : <http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#> .

<http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO> rdf:type owl:Ontology ;
                                                            <http://purl.org/dc/terms/contributor> "École de Technologie Supérieure (ÉTS)" ;
                                                            <http://purl.org/dc/terms/creator> "Adam Yousfi" ;
                                                            <http://purl.org/dc/terms/date> "2025-06-23"^^xsd:date ;
                                                            <http://purl.org/dc/terms/license> <https://creativecommons.org/publicdomain/zero/1.0/> ;
                                                            <http://purl.org/dc/terms/title> "WLCONTO: Whole-Life Costing Ontology"@en ;
                                                            <http://purl.org/vocab/vann/preferredNamespacePrefix> "wlconto" ;
                                                            <http://purl.org/vocab/vann/preferredNamespaceUri> "http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#" ;
                                                            rdfs:comment """Public release of WLCONTO (schema only, without example individuals). Ontology describing the ISO 15686-5 Whole-Life Costing standard.
Adam Yousfi, École de Technologie Supérieure (ÉTS), Montréal."""@en ;
                                                            rdfs:seeAlso <https://adamY76.github.io/WLC-PLATFORM-ETS/> ,
                                                                         <https://w3id.org/wlconto> ;
                                                            owl:versionInfo "1.0.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/contributor
<http://purl.org/dc/terms/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/date
<http://purl.org/dc/terms/date> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


###  http://www.w3.org/2002/07/owl#$
<http://www.w3.org/2002/07/owl#$> rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#ForDate
:ForDate rdf:type owl:ObjectProperty ;
         rdfs:domain :Costs ;
         rdfs:range :Time .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasConstructionCosts
:hasConstructionCosts rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :hasCosts .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasCosts
:hasCosts rdf:type owl:ObjectProperty ;
          rdfs:domain :Project ;
          rdfs:range :Costs .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasDiscountRate
:hasDiscountRate rdf:type owl:ObjectProperty ,
                          owl:SymmetricProperty ;
                 rdfs:domain :Time ;
                 rdfs:range :DiscountRate .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasDuration
:hasDuration rdf:type owl:ObjectProperty ;
             rdfs:domain :PeriodOfAnalysis ,
                         :Project ;
             rdfs:range :LifeSpan .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasEnd
:hasEnd rdf:type owl:ObjectProperty ;
        rdfs:domain :Project ;
        rdfs:range :Time .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasEndOfLifeCosts
:hasEndOfLifeCosts rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :hasCosts .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasMaintenanceCosts
:hasMaintenanceCosts rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :hasCosts .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasOperationCosts
:hasOperationCosts rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :hasCosts .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasStart
:hasStart rdf:type owl:ObjectProperty ;
          rdfs:domain :Project ;
          rdfs:range :Time .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasWLC
:hasWLC rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf owl:topObjectProperty ;
        rdfs:domain :Project ;
        rdfs:range :WholeLifeCost .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#isDiscountedValueOf
:isDiscountedValueOf rdf:type owl:ObjectProperty ;
                     rdfs:domain :DiscountedCosts ;
                     rdfs:range :Costs .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#isSumOf
:isSumOf rdf:type owl:ObjectProperty ;
         rdfs:domain :WholeLifeCost ;
         rdfs:range :DiscountedCosts .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasCostValue
:hasCostValue rdf:type owl:DatatypeProperty ;
              rdfs:domain :Costs ;
              rdfs:range xsd:decimal .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasDate
:hasDate rdf:type owl:DatatypeProperty ;
         rdfs:domain :Time ;
         rdfs:range xsd:decimal .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasDenomination
:hasDenomination rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Project ;
                 rdfs:range xsd:string .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasDiscountedCostValue
:hasDiscountedCostValue rdf:type owl:DatatypeProperty ;
                        rdfs:domain :DiscountedCosts ;
                        rdfs:range xsd:decimal .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasRateValue
:hasRateValue rdf:type owl:DatatypeProperty ;
              rdfs:domain :DiscountRate ;
              rdfs:range xsd:decimal .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#hasTotalValue
:hasTotalValue rdf:type owl:DatatypeProperty ;
               rdfs:domain :WholeLifeCost ;
               rdfs:range xsd:decimal .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#Asset
:Asset rdf:type owl:Class ;
       rdfs:subClassOf :Project .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#ConstructionCosts
:ConstructionCosts rdf:type owl:Class ;
                   rdfs:subClassOf :Costs .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#Costs
:Costs rdf:type owl:Class .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#DateOfInstallation
:DateOfInstallation rdf:type owl:Class ;
                    rdfs:subClassOf :Time .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#DiscountRate
:DiscountRate rdf:type owl:Class .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#DiscountedConstructionCosts
:DiscountedConstructionCosts rdf:type owl:Class ;
                             rdfs:subClassOf :DiscountedCosts .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#DiscountedCosts
:DiscountedCosts rdf:type owl:Class .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#DiscountedEndOfLifeCosts
:DiscountedEndOfLifeCosts rdf:type owl:Class ;
                          rdfs:subClassOf :DiscountedCosts .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#DiscountedEnvironmentalCosts
:DiscountedEnvironmentalCosts rdf:type owl:Class ;
                              rdfs:subClassOf :DiscountedCosts .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#DiscountedExternalitiesCosts
:DiscountedExternalitiesCosts rdf:type owl:Class ;
                              rdfs:subClassOf :DiscountedCosts .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#DiscountedIncome
:DiscountedIncome rdf:type owl:Class ;
                  rdfs:subClassOf :DiscountedCosts .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#DiscountedMaintenanceCosts
:DiscountedMaintenanceCosts rdf:type owl:Class ;
                            rdfs:subClassOf :DiscountedCosts .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#DiscountedNonConstructionCosts
:DiscountedNonConstructionCosts rdf:type owl:Class ;
                                rdfs:subClassOf :DiscountedCosts .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#DiscountedOperationCosts
:DiscountedOperationCosts rdf:type owl:Class ;
                          rdfs:subClassOf :DiscountedCosts .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#Element
:Element rdf:type owl:Class ;
         rdfs:subClassOf :Asset .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#EndOfLifeCosts
:EndOfLifeCosts rdf:type owl:Class ;
                rdfs:subClassOf :Costs .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#EndOfLifeDate
:EndOfLifeDate rdf:type owl:Class ;
               rdfs:subClassOf :Time .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#EnvironmentalCosts
:EnvironmentalCosts rdf:type owl:Class ;
                    rdfs:subClassOf :Costs .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#ExternalitiesCosts
:ExternalitiesCosts rdf:type owl:Class ;
                    rdfs:subClassOf :Costs .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#Income
:Income rdf:type owl:Class ;
        rdfs:subClassOf :Costs .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#LifeCycleCost
:LifeCycleCost rdf:type owl:Class ;
               rdfs:subClassOf :WholeLifeCost .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#LifeSpan
:LifeSpan rdf:type owl:Class ;
          rdfs:subClassOf :PeriodOfAnalysis .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#MaintenanceCosts
:MaintenanceCosts rdf:type owl:Class ;
                  rdfs:subClassOf :Costs .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#NonConstructionCosts
:NonConstructionCosts rdf:type owl:Class ;
                      rdfs:subClassOf :Costs .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#OperationCosts
:OperationCosts rdf:type owl:Class ;
                rdfs:subClassOf :Costs .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#PeriodOfAnalysis
:PeriodOfAnalysis rdf:type owl:Class .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#Project
:Project rdf:type owl:Class .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#Time
:Time rdf:type owl:Class .


###  http://www.semanticweb.org/adamy/ontologies/2025/WLCONTO#WholeLifeCost
:WholeLifeCost rdf:type owl:Class .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :ExternalitiesCosts
                :Income
                :LifeCycleCost
                :NonConstructionCosts
              )
] .


#################################################################
#    Rules
#################################################################

:c rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:year rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:value rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:r rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:R rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:Y rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:dc rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:base rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:denominator rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:DC rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "" ;
   rdfs:label "S2" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :Costs ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :c
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasCostValue ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> :c ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> :value
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> :ForDate ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> :c ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> :year
                                                                           ] ;
                                                                 rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                            rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                                        <http://www.w3.org/2003/11/swrl#classPredicate> :DiscountRate ;
                                                                                        <http://www.w3.org/2003/11/swrl#argument1> :r
                                                                                      ] ;
                                                                            rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                                       rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                                                                   <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasRateValue ;
                                                                                                   <http://www.w3.org/2003/11/swrl#argument1> :r ;
                                                                                                   <http://www.w3.org/2003/11/swrl#argument2> :R
                                                                                                 ] ;
                                                                                       rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                                                  rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                                                              <http://www.w3.org/2003/11/swrl#propertyPredicate> :ForDate ;
                                                                                                              <http://www.w3.org/2003/11/swrl#argument1> :r ;
                                                                                                              <http://www.w3.org/2003/11/swrl#argument2> :year
                                                                                                            ] ;
                                                                                                  rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                                                             rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                                                                         <http://www.w3.org/2003/11/swrl#classPredicate> :Time ;
                                                                                                                         <http://www.w3.org/2003/11/swrl#argument1> :year
                                                                                                                       ] ;
                                                                                                             rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                                                                        rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                                                                                                    <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasDate ;
                                                                                                                                    <http://www.w3.org/2003/11/swrl#argument1> :year ;
                                                                                                                                    <http://www.w3.org/2003/11/swrl#argument2> :Y
                                                                                                                                  ] ;
                                                                                                                        rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                                                                                   rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                                                                                               <http://www.w3.org/2003/11/swrl#classPredicate> :DiscountedCosts ;
                                                                                                                                               <http://www.w3.org/2003/11/swrl#argument1> :dc
                                                                                                                                             ] ;
                                                                                                                                   rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                                                                                              rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#BuiltinAtom> ;
                                                                                                                                                          <http://www.w3.org/2003/11/swrl#builtin> <http://www.w3.org/2003/11/swrlb#add> ;
                                                                                                                                                          <http://www.w3.org/2003/11/swrl#arguments> [ rdf:type rdf:List ;
                                                                                                                                                                                                       rdf:first :base ;
                                                                                                                                                                                                       rdf:rest [ rdf:type rdf:List ;
                                                                                                                                                                                                                  rdf:first 1 ;
                                                                                                                                                                                                                  rdf:rest ( :R
                                                                                                                                                                                                                           )
                                                                                                                                                                                                                ]
                                                                                                                                                                                                     ]
                                                                                                                                                        ] ;
                                                                                                                                              rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                                                                                                         rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#BuiltinAtom> ;
                                                                                                                                                                     <http://www.w3.org/2003/11/swrl#builtin> <http://www.w3.org/2003/11/swrlb#pow> ;
                                                                                                                                                                     <http://www.w3.org/2003/11/swrl#arguments> ( :denominator
                                                                                                                                                                                                                  :base
                                                                                                                                                                                                                  :Y
                                                                                                                                                                                                                )
                                                                                                                                                                   ] ;
                                                                                                                                                         rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                                                                                                                    rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#BuiltinAtom> ;
                                                                                                                                                                                <http://www.w3.org/2003/11/swrl#builtin> <http://www.w3.org/2003/11/swrlb#divide> ;
                                                                                                                                                                                <http://www.w3.org/2003/11/swrl#arguments> ( :DC
                                                                                                                                                                                                                             :value
                                                                                                                                                                                                                             :denominator
                                                                                                                                                                                                                           )
                                                                                                                                                                              ] ;
                                                                                                                                                                    rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                                                                                                                               rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                                                                                                                                                           <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasDiscountedCostValue ;
                                                                                                                                                                                           <http://www.w3.org/2003/11/swrl#argument1> :dc ;
                                                                                                                                                                                           <http://www.w3.org/2003/11/swrl#argument2> :DC
                                                                                                                                                                                         ] ;
                                                                                                                                                                               rdf:rest rdf:nil
                                                                                                                                                                             ]
                                                                                                                                                                  ]
                                                                                                                                                       ]
                                                                                                                                            ]
                                                                                                                                 ]
                                                                                                                      ]
                                                                                                           ]
                                                                                                ]
                                                                                     ]
                                                                          ]
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#BuiltinAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#builtin> <http://sqwrl.stanford.edu/ontologies/built-ins/3.4/sqwrl.owl#select> ;
                                                       <http://www.w3.org/2003/11/swrl#arguments> ( :c
                                                                                                    :value
                                                                                                    :DC
                                                                                                    :R
                                                                                                    :Y
                                                                                                  )
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "" ;
   rdfs:label "S1" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :Costs ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :c
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#classPredicate> :Time ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> :year
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> :ForDate ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> :c ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> :year
                                                                           ] ;
                                                                 rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                            rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                                                        <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasCostValue ;
                                                                                        <http://www.w3.org/2003/11/swrl#argument1> :c ;
                                                                                        <http://www.w3.org/2003/11/swrl#argument2> :value
                                                                                      ] ;
